{
  "manifest_version": 3,
  "name": "Bulavka AI Kit: favourite & pin ChatGPT chats and replies",
  "version": "1.2.3",
  "description": "Favourite ChatGPT chats for quick sidebar access. Pin exact GPT replies to revisit your best moments without re-explaining yourself.",
  "icons": {
    "16": "icons/icon16x16.png",
    "48": "icons/icon48x48.png",
    "128": "icons/icon128x128.png"
  },
  "permissions": [
    "alarms",
    "storage"
  ],
  "action": {
    "default_title": "Bulavka AI Kit",
    "default_icon": {
      "16": "icons/icon16x16.png",
      "48": "icons/icon48x48.png",
      "128": "icons/icon128x128.png"
    },
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/extension/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content/index.ts"
      ],
      "run_at": "document_idle"
    }
  ]
}
